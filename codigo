ARCHIVO_PROCESOS="/tmp/procesos.txt"   # archivo donde se guardan los procesos encontrados
ARCHIVO_PANTALLA="/tmp/pantalla.txt"   # archivo para mostrar los procesos ordenados
ARCHIVO_SERVICIOS="/tmp/servicios.txt" # archivo donde se guardan los servicios detenidos

pausa() {
    echo
    read -p "ENTER para continuar..." # pausa para que el usuario alcance a leer
}

listar_procesos() {
    echo
    echo "===== LISTAR PROCESOS ====="
    echo

    read -p "Ingrese usuario o * para todos: " usuario # leo el usuario o * para todos

    > "$ARCHIVO_PROCESOS" # limpia el archivo de procesos
    > "$ARCHIVO_PANTALLA" # limpia el archivo que se muestra

    contador=1 # contador para enumerar los procesos

    if [ "$usuario" = "*" ]; then
        # si el usuario ingresa *, se listan todos los procesos
        ps -e -o pid=,user=,comm= | while read pid user comando
        do
            echo "$contador) PID: $pid Usuario: $user Comando: $comando" >> "$ARCHIVO_PANTALLA"
            echo "$pid|$user|$comando" >> "$ARCHIVO_PROCESOS" # guardo los datos separados por |
            contador=$((contador + 1))
        done
    else
        # si se ingresa un usuario, se listan solo sus procesos
        ps -u "$usuario" -o pid=,user=,comm= 2>/dev/null | while read pid user comando
        do
            echo "$contador) PID: $pid Usuario: $user Comando: $comando" >> "$ARCHIVO_PANTALLA"
            echo "$pid|$user|$comando" >> "$ARCHIVO_PROCESOS"
            contador=$((contador + 1))
        done
    fi

    # si el archivo tiene contenido se muestra con less
    if [ -s "$ARCHIVO_PANTALLA" ]; then
        less "$ARCHIVO_PANTALLA"
    else
        echo "No se encontraron procesos."
    fi

    pausa
}

matar_proceso() {
    echo
    echo "===== MATAR PROCESO ====="
    echo

    # si no hay procesos listados, no se puede matar ninguno
    if [ ! -s "$ARCHIVO_PROCESOS" ]; then
        echo "Primero tienes que listar procesos."
        pausa
        return
    fi

    read -p "Ingresa el numero del proceso: " numero # numero secuencial del proceso

    contador=1
    pid_elegido=""     # guarda el PID seleccionado
    usuario_elegido="" # guarda el usuario del proceso
    comando_elegido="" # guarda el comando del proceso

    # se recorre el archivo hasta encontrar el numero elegido
    while IFS="|" read pid user comando
    do
        if [ "$contador" = "$numero" ]; then
            pid_elegido="$pid"
            usuario_elegido="$user"
            comando_elegido="$comando"
            break
        fi

        contador=$((contador + 1))
    done < "$ARCHIVO_PROCESOS"

    # si no se encuentra el PID, el numero ingresado no existe
    if [ "$pid_elegido" = "" ]; then
        echo "Numero incorrecto."
        pausa
        return
    fi

    echo "Proceso seleccionado:"
    echo "PID: $pid_elegido"
    echo "Usuario: $usuario_elegido"
    echo "Comando: $comando_elegido"
    echo

    read -p "Desea matar este proceso? (s/n): " respuesta

    if [ "$respuesta" = "s" ] || [ "$respuesta" = "S" ]; then
        kill "$pid_elegido" 2>/dev/null # intenta matar el proceso con kill

        if [ $? -eq 0 ]; then
            echo "Proceso terminado correctamente."
        else
            # si falla puede ser por permisos, por eso intenta con sudo
            echo "No se pudo terminar. Intentando con sudo..."
            sudo kill "$pid_elegido"

            if [ $? -eq 0 ]; then
                echo "Proceso terminado con sudo."
            else
                echo "No se pudo terminar el proceso."
            fi
        fi
    else
        echo "Operacion cancelada."
    fi

    pausa
}

Listar_detenidos() {
    echo
    echo "Buscando servicios inactivos..."

    > "$ARCHIVO_SERVICIOS" # limpia el archivo de servicios

    contador=1 # contador para enumerar servicios

    # lista servicios inactivos o fallidos usando systemctl
    systemctl list-units --type=service --all --state=inactive,failed --no-legend | while read -r svc load active sub description
    do
        echo "$contador) $svc $description" >> "$ARCHIVO_SERVICIOS"
        contador=$((contador + 1))
    done

    # si se encontraron servicios, se muestran pagina a pagina
    if [ -s "$ARCHIVO_SERVICIOS" ]; then
        less "$ARCHIVO_SERVICIOS"
    else
        echo "No se encontraron servicios inactivos."
    fi

    pausa
}

Activar_Servicio() {
    echo

    # revisa que primero se haya generado el listado de servicios
    if [ ! -f "$ARCHIVO_SERVICIOS" ] || [ ! -s "$ARCHIVO_SERVICIOS" ]; then
        echo "Primero debes listar los servicios. Opcion 3."
        pausa
        return
    fi

    read -p "Ingresa el numero secuencial del servicio a activar: " numero

    svc_a_activar="" # variable que guarda el servicio seleccionado

    # busca el servicio que corresponde al numero ingresado
    while read -r col_numero col_svc resto_linea
    do
        if [ "$col_numero" = "$numero)" ]; then
            svc_a_activar="$col_svc"
            break
        fi
    done < "$ARCHIVO_SERVICIOS"

    if [ "$svc_a_activar" != "" ]; then
        echo "Iniciando el servicio: $svc_a_activar..."

        systemctl start "$svc_a_activar" 2>/dev/null # intento iniciar sin sudo

        if [ $? -eq 0 ]; then
            echo "Servicio iniciado con exito."
        else
            # si falla vuelve a intentar con sudo
            echo "No se pudo iniciar el servicio. Intentando con sudo..."
            sudo systemctl start "$svc_a_activar"

            if [ $? -eq 0 ]; then
                echo "Servicio iniciado con sudo."
            else
                echo "No se pudo iniciar el servicio."
            fi
        fi
    else
        echo "Servicio no encontrado."
    fi

    pausa
}

main() {
    PS3="Seleccione una opcion: " # mensaje que aparece para pedir una opcion

    opciones=("Listar procesos" "Matar proceso" "listar detenidos" "activar servicio" "salir") # opciones del menu

    # se muestrab las selecciones enumeradas
    select opc in "${opciones[@]}"
    do
        case $opc in

            "Listar procesos")
                listar_procesos
                ;;

            "Matar proceso")
                matar_proceso
                ;;

            "listar detenidos")
                Listar_detenidos
                ;;

            "activar servicio")
                Activar_Servicio
                ;;

            "salir")
                echo "cierre del menu"
                break
                ;;

            *)
                echo "opcion incorrecta"
                ;;
        esac
    done
}

main # llamada a la funcion principal
